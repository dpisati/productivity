# ─────────────────────────────────────────────────────────────────────────────
# Root environment example. Copy to `.env` for docker compose.
# App-specific examples also live in apps/api/.env.example and apps/web/.env.example.
# ─────────────────────────────────────────────────────────────────────────────

# Postgres (local docker)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=productivity
POSTGRES_PORT=5432

# Connection string used by the API + Drizzle.
# In docker compose the host is the `postgres` service name.
DATABASE_URL=postgres://postgres:postgres@postgres:5432/productivity

# API
API_PORT=4000
NODE_ENV=development
JWT_ACCESS_SECRET=change-me-access-secret-min-16-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-16-chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
WEB_ORIGIN=http://localhost:5173

# Web
WEB_PORT=5173
VITE_API_URL=/api

# Telegram (optional — bot stays inert when unset). Built in M8.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Alexa (stubbed until M9 / later). Built later.
ALEXA_CLIENT_ID=
ALEXA_CLIENT_SECRET=
