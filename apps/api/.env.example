# API local dev (non-docker). When running via docker compose these come from root .env.
NODE_ENV=development
HOST=0.0.0.0
PORT=4000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/productivity
JWT_ACCESS_SECRET=change-me-access-secret-min-16-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-16-chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
WEB_ORIGIN=http://localhost:5173
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
